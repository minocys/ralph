            render_task_md "$line"
        done <<< "$claimable"
    fi
    if [[ -n "$active" ]]; then
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            if [[ "$first" == true ]]; then
                first=false
            else
                echo
            fi
            render_task_md "$line"
        done <<< "$active"
    fi
}
cmd_claim() {
    local lease=600
    local agent_id="${RALPH_AGENT_ID:-}"
    local target_id=""

    # Parse optional positional arg (target task ID) before flags
    if [[ $# -gt 0 ]] && [[ "$1" != --* ]]; then
        target_id="$1"; shift
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --lease) lease="$2"; shift 2 ;;
            --agent) agent_id="$2"; shift 2 ;;
            *) echo "Error: unknown flag '$1'" >&2; exit 1 ;;
        esac
    done


    local esc_agent
    esc_agent=$(sql_esc "$agent_id")

    local result

    # SQLite claim: separate SELECT → UPDATE → SELECT inside BEGIN IMMEDIATE
    # (SQLite does not support UPDATE inside CTE or FOR UPDATE SKIP LOCKED)
    local eligible_where
    if [[ -n "$target_id" ]]; then
        local esc_target
        esc_target=$(sql_esc "$target_id")
        eligible_where="$(scope_where_t "t" "${esc_target}")"
    else
        eligible_where="$(scope_filter "t")"
    fi

    # Step 1: Find eligible task ID inside a write transaction
    local claim_sql
    claim_sql="
SELECT id FROM tasks t
WHERE ${eligible_where}
  AND (t.status = 'open' OR (t.status = 'active' AND t.lease_expires_at < datetime('now')))
  AND NOT EXISTS (
      SELECT 1 FROM task_deps td
      JOIN tasks blocker ON blocker.id = td.blocked_by
      WHERE td.task_id = t.id
        AND blocker.status NOT IN ('done', 'deleted')
  )
ORDER BY t.priority ASC, t.created_at ASC
LIMIT 1;"

    local candidate_id
    candidate_id=$(sql_write "${claim_sql}" 2>/dev/null) || true

    # sql_write wraps in BEGIN IMMEDIATE...COMMIT, but we need the SELECT + UPDATE
    # in the same transaction. Restructure: build full transaction SQL.
    # Re-do with a single transaction that selects, updates, and returns result.
    local tx_sql=".bail on
BEGIN IMMEDIATE;
CREATE TEMP TABLE IF NOT EXISTS _claim_candidate (task_uuid TEXT);
DELETE FROM _claim_candidate;
INSERT INTO _claim_candidate
SELECT id FROM tasks t
WHERE ${eligible_where}
  AND (t.status = 'open' OR (t.status = 'active' AND t.lease_expires_at < datetime('now')))
  AND NOT EXISTS (
      SELECT 1 FROM task_deps td
      JOIN tasks blocker ON blocker.id = td.blocked_by
      WHERE td.task_id = t.id
        AND blocker.status NOT IN ('done', 'deleted')
  )
ORDER BY t.priority ASC, t.created_at ASC
LIMIT 1;
UPDATE tasks
SET status = 'active',
    assignee = '${esc_agent}',
    lease_expires_at = datetime('now', '+${lease} seconds'),
    retry_count = CASE
        WHEN tasks.status = 'active' THEN tasks.retry_count + 1
        ELSE tasks.retry_count
    END,
    updated_at = datetime('now')
WHERE id = (SELECT task_uuid FROM _claim_candidate)
  AND status IN ('open', 'active');
SELECT json_object(
    'id', c.slug,
    't', c.title,
    'd', c.description,
    'p', c.priority,
    's', c.status,
    'cat', c.category,
    'spec', c.spec_ref,
    'ref', c.ref,
    'assignee', c.assignee,
    'lease_expires_at', c.lease_expires_at,
    'retry_count', c.retry_count,
    'deps', COALESCE((SELECT json_group_array(bt.slug) FROM task_deps td JOIN tasks bt ON bt.id = td.blocked_by WHERE td.task_id = c.id), json('[]')),
    'steps', COALESCE(json(c.steps), json('[]')),
    'blocker_results', COALESCE((
        SELECT json_group_object(bt.slug, json(bt.result))
        FROM task_deps td
        JOIN tasks bt ON bt.id = td.blocked_by
        WHERE td.task_id = c.id AND bt.result IS NOT NULL
    ), json('{}'))
)
FROM tasks c
WHERE c.id = (SELECT task_uuid FROM _claim_candidate);
COMMIT;"

    result=$(printf '%s\n' "$tx_sql" | sqlite_cmd)

    if [[ -z "$result" ]]; then
        if [[ -n "$target_id" ]]; then
            echo "Task not eligible" >&2
        else
            echo "No eligible tasks" >&2
        fi
        exit 2
    fi

    render_task_md "$result"
}
cmd_renew() {
    local task_id=""
    local lease=600
    local agent_id="${RALPH_AGENT_ID:-}"

    # Parse positional arg and flags
    if [[ $# -gt 0 ]] && [[ "$1" != --* ]]; then
        task_id="$1"; shift
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --lease) lease="$2"; shift 2 ;;
            --agent) agent_id="$2"; shift 2 ;;
            *) echo "Error: unknown flag '$1'" >&2; exit 1 ;;
        esac
    done

    if [[ -z "$task_id" ]]; then
        echo "Error: missing task ID" >&2
        echo "Usage: ralph task renew <id> [--lease N]" >&2
        exit 1
    fi

    local esc_id esc_agent
    esc_id=$(sql_esc "$task_id")
    esc_agent=$(sql_esc "$agent_id")

    # Single atomic UPDATE — eliminates TOCTOU race between check and update
    local updated
    updated=$(sqlite_cmd "
        UPDATE tasks
        SET lease_expires_at = datetime('now', '+${lease} seconds'),
            updated_at = datetime('now')
        WHERE $(scope_where "${esc_id}")
          AND assignee = '${esc_agent}'
          AND status = 'active'
        RETURNING slug;
    ")

    if [[ -n "$updated" ]]; then
        echo "renewed $task_id"
        return 0
    fi

    # UPDATE matched no rows — diagnose the reason
    local status
    status=$(sqlite_cmd "SELECT status FROM tasks WHERE $(scope_where "${esc_id}");")
    if [[ -z "$status" ]]; then
        echo "Error: task '$task_id' not found" >&2
        exit 2
    fi
    if [[ "$status" != "active" ]]; then
        echo "Error: task '$task_id' is not active (status: $status)" >&2
        exit 1
    fi
    echo "Error: agent '$agent_id' is not the assignee of task '$task_id'" >&2
    exit 1
}
cmd_done() {
    local task_id="${1:-}"
    shift 2>/dev/null || true

    if [[ -z "$task_id" ]]; then
        echo "Error: missing task ID" >&2
        echo "Usage: ralph task done <id> [--result '<json>']" >&2
        exit 1
    fi

    local result_json=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --result) result_json="$2"; shift 2 ;;
            *) echo "Error: unknown flag '$1'" >&2; exit 1 ;;
        esac
    done

    # Validate result JSON contains required 'commit' key
    if [[ -n "$result_json" ]]; then
        if ! printf '%s' "$result_json" | jq -e '.commit' >/dev/null 2>&1; then
            echo "Error: result JSON must include a 'commit' key" >&2
            exit 1
        fi
    fi

    local esc_id
    esc_id=$(sql_esc "$task_id")

    # Check task exists and get current status
    local current_status
    current_status=$(sqlite_cmd "SELECT status FROM tasks WHERE $(scope_where "${esc_id}");")

    if [[ -z "$current_status" ]]; then
        echo "Error: task '$task_id' not found" >&2
        exit 2
    fi

    if [[ "$current_status" != "active" ]]; then
        echo "Error: task '$task_id' is not active (status: $current_status)" >&2
        exit 1
    fi

    # Build the UPDATE with optional result JSON
    local result_clause
    if [[ -n "$result_json" ]]; then
        local esc_result
        esc_result=$(sql_esc "$result_json")
        result_clause=", result = '${esc_result}'"
    else
        result_clause=""
    fi

    sql_write "
        UPDATE tasks
        SET status = 'done',
            updated_at = datetime('now')
            ${result_clause}
        WHERE $(scope_where "${esc_id}");
    " > /dev/null

    echo "done $task_id"
}
cmd_fail() {
    local task_id="${1:-}"
    shift 2>/dev/null || true

    if [[ -z "$task_id" ]]; then
        echo "Error: missing task ID" >&2
        echo "Usage: ralph task fail <id> [--reason \"<text>\"]" >&2
        exit 1
    fi

    local reason=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --reason) reason="$2"; shift 2 ;;
            *) echo "Error: unknown flag '$1'" >&2; exit 1 ;;
        esac
    done


    local esc_id
    esc_id=$(sql_esc "$task_id")

    # Check task exists and get current status
    local current_status
    current_status=$(sqlite_cmd "SELECT status FROM tasks WHERE $(scope_where "${esc_id}");")

    if [[ -z "$current_status" ]]; then
        echo "Error: task '$task_id' not found" >&2
        exit 2
    fi

    if [[ "$current_status" != "active" ]]; then
        echo "Error: task '$task_id' is not active (status: $current_status)" >&2
        exit 1
    fi

    local esc_reason
    esc_reason=$(sql_esc "$reason")

    # Release task back to open: clear assignee, clear lease, increment retry_count, store reason
    local fail_reason_sql="NULL"
    if [[ -n "$reason" ]]; then
        fail_reason_sql="'${esc_reason}'"
    fi

    sql_write "
        UPDATE tasks
        SET status = 'open',
            assignee = NULL,
            lease_expires_at = NULL,
            retry_count = retry_count + 1,
            fail_reason = ${fail_reason_sql},
            updated_at = datetime('now')
        WHERE $(scope_where "${esc_id}");
    " > /dev/null

    echo "failed $task_id"
}
cmd_list() {
    local status_filter=""
    local assignee_filter=""
    local markdown_output=0
    local all_tasks=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)      all_tasks=1; shift ;;
            --status)   status_filter="$2"; shift 2 ;;
            --assignee) assignee_filter="$2"; shift 2 ;;
            --markdown) markdown_output=1; shift ;;
            *) echo "Error: unknown flag '$1'" >&2; exit 1 ;;
        esac
    done

    # --all and --status are mutually exclusive
    if [[ "$all_tasks" -eq 1 ]] && [[ -n "$status_filter" ]]; then
        echo "Error: --all and --status are mutually exclusive" >&2
        exit 1
    fi

    # Build WHERE clause (always scoped)
    local where_clause
    if [[ "$all_tasks" -eq 1 ]]; then
        where_clause="WHERE $(scope_filter "t")"
    elif [[ -n "$status_filter" ]]; then
        local in_list=""
        IFS=',' read -ra statuses <<< "$status_filter"
        for s in "${statuses[@]}"; do
            s=$(printf '%s' "$s" | xargs)
            if [[ -n "$in_list" ]]; then
                in_list+=","
            fi
            in_list+="'${s}'"
        done
        where_clause="WHERE $(scope_filter "t") AND t.status IN (${in_list})"
    else
        where_clause="WHERE $(scope_filter "t") AND t.status != 'deleted'"
    fi

    if [[ -n "$assignee_filter" ]]; then
        local esc_assignee
        esc_assignee=$(printf '%s' "$assignee_filter" | sed "s/'/''/g")
        where_clause+=" AND t.assignee = '${esc_assignee}'"
    fi

    if [[ "$markdown_output" -eq 1 ]]; then
        # Markdown-KV output via render_task_md (scoped)
        local jsonl
        jsonl=$(sqlite_cmd "
            SELECT json_object(
                'id', t.slug,
                't', t.title,
                'd', t.description,
                'p', t.priority,
                's', t.status,
                'cat', t.category,
                'spec', t.spec_ref,
                'ref', t.ref,
                'assignee', t.assignee,
                'deps', COALESCE((SELECT json_group_array(bt.slug) FROM task_deps td JOIN tasks bt ON bt.id = td.blocked_by WHERE td.task_id = t.id), json('[]')),
                'steps', COALESCE(json(t.steps), json('[]'))
            )
            FROM tasks t
            ${where_clause}
            ORDER BY t.priority ASC, t.created_at ASC;
        ")

        if [[ -z "$jsonl" ]]; then
            return 0
        fi

        local first=true
        local line
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            if [[ "$first" == true ]]; then
                first=false
            else
                echo
            fi
            render_task_md "$line"
        done <<< "$jsonl"
    else
        # Table output: ID, P, S, CAT, TITLE, AGENT (scoped)
        local result
        result=$(sqlite_cmd "
            SELECT t.slug, t.priority, t.status, COALESCE(t.category, '-'), t.title, COALESCE(t.assignee, '-')
            FROM tasks t
            ${where_clause}
            ORDER BY t.priority ASC, t.created_at ASC;
        ")

        if [[ -z "$result" ]]; then
            return 0
        fi

        # Print header and rows with column alignment
        printf '%-20s %s %-8s %-5s %-35s %s\n' "ID" "P" "S" "CAT" "TITLE" "AGENT"
        while IFS='|' read -r id priority status category title assignee; do
            printf '%-20s %s %-8s %-5s %-35s %s\n' "$id" "$priority" "$status" "$category" "$title" "$assignee"
        done <<< "$result"
    fi
}
