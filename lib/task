    if [[ "$has_description" -eq 1 ]]; then
        set_parts+=("description = '$(sql_esc "$description")'")
    fi
    if [[ "$has_status" -eq 1 ]]; then
        set_parts+=("status = '$(sql_esc "$status")'")
    fi
    # Always set updated_at
    set_parts+=("updated_at = datetime('now')")

    local set_clause
    set_clause=$(IFS=', '; echo "${set_parts[*]}")

    local sql="UPDATE tasks SET ${set_clause} WHERE $(scope_where "${esc_id}");"

    # If --steps provided, update tasks.steps column (JSON array TEXT)
    if [[ "$has_steps" -eq 1 ]]; then
        local steps_val="NULL"
        if [[ -n "$steps_json" ]]; then
            steps_val=$(build_steps_literal "$steps_json")
        fi
        sql+="
UPDATE tasks SET steps = ${steps_val} WHERE $(scope_where "${esc_id}");"
    fi

    sql_write "$sql" > /dev/null
    echo "updated $id"
}
cmd_delete() {
    local id="${1:-}"

    if [[ -z "$id" ]]; then
        echo "Error: missing task ID" >&2
        echo "Usage: ralph task delete <id>" >&2
        exit 1
    fi


    local esc_id
    esc_id=$(sql_esc "$id")

    # Check task exists
    local current_status
    current_status=$(sqlite_cmd "SELECT status FROM tasks WHERE $(scope_where "${esc_id}");")

    if [[ -z "$current_status" ]]; then
        echo "Error: task '$id' not found" >&2
        exit 2
    fi

    # Soft delete: set status to 'deleted', set deleted_at and updated_at
    sql_write "
        UPDATE tasks
        SET status = 'deleted', deleted_at = datetime('now'), updated_at = datetime('now')
        WHERE $(scope_where "${esc_id}");
    " > /dev/null

    echo "deleted $id"
}
cmd_deps() {
    local id="${1:-}"

    if [[ -z "$id" ]]; then
        echo "Error: missing task ID" >&2
        echo "Usage: ralph task deps <id>" >&2
        exit 1
    fi


    local esc_id
    esc_id=$(sql_esc "$id")

    # Check task exists
    local task_exists
    task_exists=$(sqlite_cmd "SELECT id FROM tasks WHERE $(scope_where "${esc_id}");")
    if [[ -z "$task_exists" ]]; then
        echo "Error: task '$id' not found" >&2
        exit 2
    fi

    # Recursive CTE to walk the full dependency tree (use UUID internally, display slug)
    local tree_output
    tree_output=$(sqlite_cmd "
        WITH RECURSIVE dep_tree AS (
            SELECT td.blocked_by, t.slug, t.status, t.title, 1 AS depth, td.task_id AS parent
            FROM task_deps td
            JOIN tasks t ON t.id = td.blocked_by
            WHERE td.task_id = $(slug_uuid_subq "${esc_id}")
            UNION
            SELECT td.blocked_by, t.slug, t.status, t.title, dt.depth + 1, td.task_id AS parent
            FROM task_deps td
            JOIN tasks t ON t.id = td.blocked_by
            JOIN dep_tree dt ON dt.blocked_by = td.task_id
        )
        SELECT slug, status, title, depth FROM dep_tree
        ORDER BY depth ASC, slug ASC;
    ")

    if [[ -z "$tree_output" ]]; then
        echo "(no dependencies)"
        return 0
    fi

    # Print tree with indentation based on depth
    while IFS='|' read -r dep_id dep_status dep_title dep_depth; do
        local indent=""
        for ((i=1; i<dep_depth; i++)); do
            indent+="  "
        done
        printf '%s%s [%s] %s\n' "$indent" "$dep_id" "$dep_status" "$dep_title"
    done <<< "$tree_output"
}
cmd_block() {
    local id="${1:-}"
    shift 2>/dev/null || true

    if [[ -z "$id" ]]; then
        echo "Error: missing task ID" >&2
        echo "Usage: ralph task block <id> --by <blocker-id>" >&2
        exit 1
    fi

    local blocker_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --by) blocker_id="$2"; shift 2 ;;
            *) echo "Error: unknown flag '$1'" >&2; exit 1 ;;
        esac
    done

    if [[ -z "$blocker_id" ]]; then
        echo "Error: missing --by <blocker-id>" >&2
        echo "Usage: ralph task block <id> --by <blocker-id>" >&2
        exit 1
    fi


    local esc_id esc_blocker
    esc_id=$(sql_esc "$id")
    esc_blocker=$(sql_esc "$blocker_id")

    # Check both tasks exist
    local task_exists
    task_exists=$(sqlite_cmd "SELECT id FROM tasks WHERE $(scope_where "${esc_id}");")
    if [[ -z "$task_exists" ]]; then
        echo "Error: task '$id' not found" >&2
        exit 2
    fi

    local blocker_exists
    blocker_exists=$(sqlite_cmd "SELECT id FROM tasks WHERE $(scope_where "${esc_blocker}");")
    if [[ -z "$blocker_exists" ]]; then
        echo "Error: blocker task '$blocker_id' not found" >&2
        exit 2
    fi

    # Insert dependency (resolve slugs to UUIDs)
    sql_write "
        INSERT INTO task_deps (task_id, blocked_by)
        VALUES ($(slug_uuid_subq "${esc_id}"), $(slug_uuid_subq "${esc_blocker}"))
        ON CONFLICT DO NOTHING;
    " > /dev/null

    echo "blocked $id by $blocker_id"
}
cmd_unblock() {
    local id="${1:-}"
    shift 2>/dev/null || true

    if [[ -z "$id" ]]; then
        echo "Error: missing task ID" >&2
        echo "Usage: ralph task unblock <id> --by <blocker-id>" >&2
        exit 1
    fi

    local blocker_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --by) blocker_id="$2"; shift 2 ;;
            *) echo "Error: unknown flag '$1'" >&2; exit 1 ;;
        esac
    done

    if [[ -z "$blocker_id" ]]; then
        echo "Error: missing --by <blocker-id>" >&2
        echo "Usage: ralph task unblock <id> --by <blocker-id>" >&2
        exit 1
    fi


    local esc_id esc_blocker
    esc_id=$(sql_esc "$id")
    esc_blocker=$(sql_esc "$blocker_id")

    # Delete the dependency (resolve slugs to UUIDs) and check if row existed
    local deleted_id
    deleted_id=$(sqlite_cmd "
        DELETE FROM task_deps
        WHERE task_id = $(slug_uuid_subq "${esc_id}") AND blocked_by = $(slug_uuid_subq "${esc_blocker}")
        RETURNING task_id;
    ")

    if [[ -z "$deleted_id" ]]; then
        echo "Error: dependency not found" >&2
        exit 2
    fi

    echo "unblocked $id from $blocker_id"
}

cmd_agent_register() {
    local agent_id attempt max_attempts=10
    local pid="$$"
    local host="${HOSTNAME:-$(hostname)}"

    for (( attempt=0; attempt<max_attempts; attempt++ )); do
        # Generate random 4-char hex ID
        agent_id=$(head -c 2 /dev/urandom | od -An -tx1 | tr -d ' \n')

        # Try to insert; ON CONFLICT means collision — retry
        local result
        result=$(sqlite_cmd "
            INSERT INTO agents (id, pid, hostname, scope_repo, scope_branch)
            VALUES ('$(sql_esc "$agent_id")', $pid, '$(sql_esc "$host")', '${ESC_SCOPE_REPO}', '${ESC_SCOPE_BRANCH}')
            ON CONFLICT (id) DO NOTHING
            RETURNING id;
        " 2>&1)

        if [[ -n "$result" ]]; then
            echo "$agent_id"
            return 0
        fi
    done

    echo "Error: failed to generate unique agent ID after $max_attempts attempts" >&2
    exit 1
}

cmd_agent_list() {
    local result
    result=$(sqlite_cmd "
        SELECT id, pid, hostname, started_at, status
        FROM agents
        WHERE status = 'active'
          AND scope_repo = '${ESC_SCOPE_REPO}'
          AND scope_branch = '${ESC_SCOPE_BRANCH}'
        ORDER BY started_at DESC;
    ")

    if [[ -z "$result" ]]; then
        return 0
    fi

    printf '%-6s %-8s %-20s %-25s %s\n' "ID" "PID" "HOSTNAME" "STARTED" "STATUS"
    while IFS='|' read -r id pid hostname started status; do
        printf '%-6s %-8s %-20s %-25s %s\n' "$id" "$pid" "$hostname" "$started" "$status"
    done <<< "$result"
}

cmd_agent_deregister() {
    local id="${1:-}"
    if [[ -z "$id" ]]; then
        echo "Error: missing agent ID" >&2
        echo "Usage: ralph task agent deregister <id>" >&2
        exit 1
    fi


    local esc_id
    esc_id=$(sql_esc "$id")

    # Check agent exists
    local current
    current=$(sqlite_cmd "SELECT id FROM agents WHERE id = '${esc_id}';")

    if [[ -z "$current" ]]; then
        echo "Error: agent '$id' not found" >&2
        exit 2
    fi

    sql_write "UPDATE agents SET status = 'stopped' WHERE id = '${esc_id}';" > /dev/null

    echo "deregistered $id"
}

cmd_agent() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true
    case "$subcmd" in
        register)   cmd_agent_register "$@" ;;
        list)       cmd_agent_list "$@" ;;
        deregister) cmd_agent_deregister "$@" ;;
        "")
            echo "Error: missing agent subcommand" >&2
            echo "Usage: ralph task agent <register|list|deregister>" >&2
            exit 1
            ;;
        *)
            echo "Error: unknown agent subcommand '$subcmd'" >&2
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
main() {
    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "$cmd" in
        --help|-h)
            usage
            exit 0
            ;;
        plan-sync)    db_check; ensure_schema; require_scope; cmd_plan_sync "$@" ;;
        plan-export)  echo "Error: unknown command 'plan-export'. Use 'ralph task list --all' instead." >&2; exit 1 ;;
        plan-status)  db_check; ensure_schema; require_scope; cmd_plan_status "$@" ;;
        peek)         db_check; ensure_schema; require_scope; cmd_peek "$@" ;;
        claim)        db_check; ensure_schema; require_scope; cmd_claim "$@" ;;
        renew)        db_check; ensure_schema; require_scope; cmd_renew "$@" ;;
        done)         db_check; ensure_schema; require_scope; cmd_done "$@" ;;
        fail)         db_check; ensure_schema; require_scope; cmd_fail "$@" ;;
        list)         db_check; ensure_schema; require_scope; cmd_list "$@" ;;
        show)         db_check; ensure_schema; require_scope; cmd_show "$@" ;;
        create)       db_check; ensure_schema; require_scope; cmd_create "$@" ;;
        update)       db_check; ensure_schema; require_scope; cmd_update "$@" ;;
        delete)       db_check; ensure_schema; require_scope; cmd_delete "$@" ;;
        deps)         db_check; ensure_schema; require_scope; cmd_deps "$@" ;;
        block)        db_check; ensure_schema; require_scope; cmd_block "$@" ;;
        unblock)      db_check; ensure_schema; require_scope; cmd_unblock "$@" ;;
        agent)        db_check; ensure_schema; require_scope; cmd_agent "$@" ;;
        _render-md)   render_task_md "$1" ;;
        _get-scope)   get_scope; echo "repo:$SCOPE_REPO"; echo "branch:$SCOPE_BRANCH" ;;
        "")
            echo "Error: missing command" >&2
            echo "" >&2
            usage >&2
            exit 1
            ;;
        *)
            echo "Error: unknown command '$cmd'" >&2
            exit 1
            ;;
    esac
}

main "$@"
